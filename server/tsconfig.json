{
  "extends": "./.nitro/types/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "paths": {
      "#app/*": ["./server/*"],
      "@shared/*": ["./../shared/*"]
    },
    "resolvePackageJsonImports": true,
    "types": ["node"],
    "skipLibCheck": true
  }
}
